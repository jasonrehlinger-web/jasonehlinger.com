---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  keywords?: string;
}

const {
  title,
  description = 'Jason Ehlinger — leadership coach, personal finance expert, and CEO of Taika Translations. Veteran entrepreneur helping business owners build high-performing teams and lasting wealth.',
  image = '/jason-headshot.jpg',
  keywords = 'leadership coach, business coach, personal finance coach, executive coaching, team building, wealth building, veteran entrepreneur, financial freedom, leadership development, performance coaching',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  <meta name="msvalidate.01" content="8FD88F84F8646AD9EB86D7930F6F989C" />

  <title>{title} | Jason Ehlinger</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={`${title} | Jason Ehlinger`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={image} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Jason Ehlinger" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | Jason Ehlinger`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />

  <!-- Structured Data: Person -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Jason Ehlinger",
      "url": "https://www.jasonehlinger.com",
      "jobTitle": "Leadership Coach, CEO",
      "description": "Leadership coach, personal finance expert, CEO of Taika Translations, U.S. Air Force veteran, husband and father of 8. Helping entrepreneurs build high-performing teams and lasting wealth.",
      "worksFor": {
        "@type": "Organization",
        "name": "Taika Translations",
        "url": "https://www.taikatranslations.com"
      },
      "sameAs": [
        "https://www.instagram.com/jason.ehlinger/",
        "https://www.facebook.com/jason.r.ehlinger",
        "https://www.youtube.com/@Visiontribemoney"
      ],
      "knowsAbout": [
        "Leadership Coaching",
        "Business Coaching",
        "Personal Finance",
        "Wealth Building",
        "Team Building",
        "Executive Coaching",
        "Entrepreneurship",
        "Zero-Based Budgeting",
        "Military Entrepreneurship",
        "Leadership Development"
      ]
    }
  </script>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
