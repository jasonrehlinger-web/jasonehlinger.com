---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Compound Interest Calculator — Watch Your Money Multiply"
  description="Use Jason Ehlinger's free compound interest calculator to see how interest compounds over time. The eighth wonder of the world — visualized."
  keywords="compound interest calculator, compound interest formula, how compound interest works, compound growth calculator, interest calculator"
>

  <section class="page-hero">
    <span class="section-label">Free Tool</span>
    <h1>Compound Interest Calculator</h1>
    <p>"Compound interest is the eighth wonder of the world. He who understands it, earns it. He who doesn't, pays it." — Albert Einstein</p>
  </section>

  <section class="section">
    <div class="container" style="max-width:1040px;">
      <div class="calc-grid">

        <div class="calc-inputs">
          <div class="field-group">
            <label>Starting Amount</label>
            <div class="field-wrap">
              <span class="field-symbol">$</span>
              <input type="number" id="principal" value="5000" min="0" step="500" />
            </div>
          </div>

          <div class="field-group">
            <label>Monthly Addition</label>
            <div class="field-wrap">
              <span class="field-symbol">$</span>
              <input type="number" id="addition" value="200" min="0" step="50" />
            </div>
          </div>

          <div class="field-group">
            <label>Annual Interest Rate</label>
            <div class="field-wrap">
              <input type="number" id="ciRate" value="8" min="0" max="30" step="0.5" />
              <span class="field-symbol right">%</span>
            </div>
          </div>

          <div class="field-group">
            <label>Choose your compounding frequency. (Daily is the most common.)</label>
            <div class="freq-btns">
              <button class="freq-btn" data-freq="1">Yearly</button>
              <button class="freq-btn" data-freq="12">Monthly</button>
              <button class="freq-btn active" data-freq="365">Daily</button>
            </div>
          </div>

          <div class="field-group">
            <label>Current Age</label>
            <div class="field-wrap">
              <input type="number" id="currentAge" value="30" min="10" max="80" step="1" />
              <span class="field-symbol right">yrs</span>
            </div>
          </div>

          <div class="field-group">
            <label>Target Age</label>
            <div class="field-wrap">
              <input type="number" id="targetAge" value="60" min="20" max="90" step="1" />
              <span class="field-symbol right">yrs</span>
            </div>
          </div>

          <button class="calc-btn" id="calcBtn">Calculate</button>
        </div>

        <div class="calc-results">
          <div class="results-header">
            <div>
              <p class="result-eyebrow">Estimated Savings Value</p>
              <p class="result-subtext" id="resultSubtext">In 30 years, your savings could be worth:</p>
            </div>
            <div class="result-number" id="ciBalance">$0</div>
          </div>

          <div class="result-stats">
            <div class="stat-col">
              <span class="stat-label">Initial Balance</span>
              <span class="stat-value" id="ciPrincipal">$0</span>
              <span class="stat-pct" id="pctPrincipal">0% of Total</span>
            </div>
            <div class="stat-col">
              <span class="stat-label">Contributions</span>
              <span class="stat-value" id="ciContributions">$0</span>
              <span class="stat-pct" id="pctContribs">0% of Total</span>
            </div>
            <div class="stat-col">
              <span class="stat-label">Growth</span>
              <span class="stat-value gold" id="ciInterest">$0</span>
              <span class="stat-pct" id="pctInterest">0% of Total</span>
            </div>
          </div>

          <div class="chart-container">
            <canvas id="ciChart" height="200"></canvas>
            
          </div>

          <div class="result-cta">
            <p>Ready to put compound interest to work for your family?</p>
            <a href="/contact" class="btn btn-gold" style="display:inline-block;margin-top:0.6rem;">Work With Jason</a>
          </div>
        </div>
      </div>

      <div class="explainer">
        <h3>Why Compound Interest Changes Everything</h3>
        <p>With simple interest, you only earn interest on your original principal. With compound interest, you earn interest on your interest — and over time, that difference becomes massive. The earlier you start, the more time your money has to compound exponentially.</p>
      </div>
    </div>
  </section>

</Layout>

<style>
  .calc-grid { display:grid; grid-template-columns:380px 1fr; gap:2.5rem; align-items:start; }
  .calc-inputs { background:#fff; border:1px solid #e5e5e5; border-radius:8px; padding:2rem; box-shadow:0 2px 12px rgba(0,0,0,0.06); }
  .field-group { margin-bottom:1.4rem; }
  .field-group label { display:block; font-weight:700; font-size:0.9rem; margin-bottom:0.5rem; color:var(--black); line-height:1.4; }
  .field-wrap { display:flex; align-items:center; border:2px solid #ddd; border-radius:6px; overflow:hidden; background:#fafafa; transition:border-color 0.2s; }
  .field-wrap:focus-within { border-color:var(--gold); background:#fff; }
  .field-symbol { padding:0.7rem 0.85rem; font-size:1rem; font-weight:700; color:var(--gray); background:transparent; user-select:none; }
  .field-symbol.right { border-left:1px solid #e5e5e5; }
  .field-wrap input { flex:1; border:none; background:transparent; padding:0.7rem 0.5rem; font-size:1.05rem; font-weight:600; color:var(--black); min-width:0; }
  .field-wrap input:focus { outline:none; }
  .freq-btns { display:flex; border:2px solid #ddd; border-radius:6px; overflow:hidden; }
  .freq-btn { flex:1; padding:0.65rem 0; border:none; background:#fafafa; font-size:0.9rem; font-weight:600; color:var(--gray); cursor:pointer; transition:background 0.2s,color 0.2s; border-right:1px solid #ddd; }
  .freq-btn:last-child { border-right:none; }
  .freq-btn.active { background:var(--gold); color:#fff; }
  .calc-btn { width:100%; padding:0.9rem; background:var(--gold); color:#fff; border:none; border-radius:6px; font-size:1rem; font-weight:800; letter-spacing:0.03em; cursor:pointer; text-transform:uppercase; transition:opacity 0.2s; margin-top:0.25rem; }
  .calc-btn:hover { opacity:0.88; }
  .calc-results { background:#fff; border:1px solid #e5e5e5; border-radius:8px; padding:2rem; box-shadow:0 2px 12px rgba(0,0,0,0.06); }
  .results-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:1.5rem; padding-bottom:1.5rem; border-bottom:1px solid #eee; gap:1rem; }
  .result-eyebrow { font-size:0.75rem; font-weight:800; text-transform:uppercase; letter-spacing:0.08em; color:var(--black); margin-bottom:0.3rem; }
  .result-subtext { font-size:0.85rem; color:var(--gray); }
  .result-number { font-size:2.2rem; font-weight:900; color:var(--black); white-space:nowrap; }
  .result-stats { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; padding-bottom:1.5rem; border-bottom:1px solid #eee; margin-bottom:1.5rem; }
  .stat-col { display:flex; flex-direction:column; gap:0.2rem; }
  .stat-label { font-size:0.7rem; font-weight:800; text-transform:uppercase; letter-spacing:0.06em; color:#aaa; }
  .stat-value { font-size:1.3rem; font-weight:800; color:var(--black); }
  .stat-value.gold { color:var(--gold); }
  .stat-pct { font-size:0.75rem; color:var(--gray); }
  .chart-container { margin-bottom:1.5rem; }
  canvas { width:100%; display:block; }
  .result-cta { border-top:1px solid #eee; padding-top:1.25rem; text-align:center; font-size:0.95rem; color:var(--gray); }
  .explainer { margin-top:2.5rem; padding:2rem; background:var(--light-gray); border-radius:8px; }
  .explainer h3 { font-size:1.1rem; margin-bottom:0.75rem; }
  .explainer p { color:var(--gray); font-size:0.95rem; }
  @media (max-width:860px) { .calc-grid { grid-template-columns:1fr; } .result-number { font-size:1.7rem; } }
</style>

<script>
  var currentFreq = 365;

  function fmtFull(n) {
    return '$' + Math.round(n).toLocaleString('en-US');
  }

  function fmtShort(n) {
    if (n >= 1000000) return '$' + (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000) return '$' + Math.round(n / 1000) + 'K';
    return '$' + Math.round(n);
  }

  function getBalance(P, addPerPeriod, r, periods) {
    if (r === 0) return P + addPerPeriod * periods;
    return P * Math.pow(1 + r, periods) + addPerPeriod * ((Math.pow(1 + r, periods) - 1) / r);
  }

  function calcCompound() {
    var P = parseFloat(document.getElementById('principal').value) || 0;
    var add = parseFloat(document.getElementById('addition').value) || 0;
    var annualRate = parseFloat(document.getElementById('ciRate').value) || 0;
    var freq = currentFreq;
    var currentAge = parseInt(document.getElementById('currentAge').value) || 30;
    var targetAge = parseInt(document.getElementById('targetAge').value) || 60;
    var years = Math.max(targetAge - currentAge, 1);

    var r = annualRate / 100 / freq;
    var addPerPeriod = add * 12 / freq;
    var totalPeriods = years * freq;

    var balance = getBalance(P, addPerPeriod, r, totalPeriods);
    var totalContribs = add * 12 * years;
    var interest = Math.max(balance - P - totalContribs, 0);
    var total = balance || 1;

    document.getElementById('ciBalance').textContent = fmtFull(balance);
    document.getElementById('resultSubtext').textContent = 'In ' + years + ' year' + (years !== 1 ? 's' : '') + ', your savings could be worth:';
    document.getElementById('ciPrincipal').textContent = fmtFull(P);
    document.getElementById('ciContributions').textContent = fmtFull(totalContribs);
    document.getElementById('ciInterest').textContent = fmtFull(interest);
    document.getElementById('pctPrincipal').textContent = Math.round(P / total * 100) + '% of Total';
    document.getElementById('pctContribs').textContent = Math.round(totalContribs / total * 100) + '% of Total';
    document.getElementById('pctInterest').textContent = Math.round(interest / total * 100) + '% of Total';

    buildChart(P, addPerPeriod, r, freq, years);
  }

  function buildChart(P, addPerPeriod, r, freq, years) {
    var canvas = document.getElementById('ciChart');
    var ctx = canvas.getContext('2d');
    var currentYear = new Date().getFullYear();

    // Collect data points — max 30 bars
    var totalBars = Math.min(years, 30);
    var step = years / totalBars;
    var data = [];
    for (var i = 1; i <= totalBars; i++) {
      var yr = Math.round(i * step);
      var bal = getBalance(P, addPerPeriod, r, yr * freq);
      data.push({ yr: yr, bal: bal, label: String(currentYear + yr) });
    }

    var maxBal = 0;
    for (var j = 0; j < data.length; j++) {
      if (data[j].bal > maxBal) maxBal = data[j].bal;
    }
    maxBal = maxBal || 1;

    // Canvas dimensions
    var W = canvas.parentElement.clientWidth || 500;
    var H = 220;
    var padLeft = 60;
    var padTop = 10;
    var padBottom = 24;
    var chartH = H - padTop - padBottom;
    var chartW = W - padLeft;

    canvas.width = W;
    canvas.height = H;
    ctx.clearRect(0, 0, W, H);

    // Y-axis labels and grid lines
    var ySteps = 5;
    ctx.font = '11px Inter, sans-serif';
    ctx.fillStyle = '#aaa';
    ctx.textAlign = 'right';
    for (var k = 0; k <= ySteps; k++) {
      var val = (maxBal / ySteps) * k;
      var y = padTop + chartH - (k / ySteps) * chartH;
      ctx.fillText(fmtShort(val), padLeft - 6, y + 4);
      ctx.strokeStyle = '#eee';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(padLeft, y);
      ctx.lineTo(W, y);
      ctx.stroke();
    }

    // Bars
    var barGap = 3;
    var barW = Math.max(2, (chartW / data.length) - barGap);
    var goldColor = '#C8982A';
    var grayColor = '#d4d4d4';

    for (var m = 0; m < data.length; m++) {
      var barH = (data[m].bal / maxBal) * chartH;
      var x = padLeft + m * (barW + barGap);
      var y2 = padTop + chartH - barH;
      ctx.fillStyle = (m === data.length - 1) ? goldColor : grayColor;
      ctx.beginPath();
      if (ctx.roundRect) { ctx.roundRect(x, y2, barW, barH, [2, 2, 0, 0]); } else { ctx.rect(x, y2, barW, barH); }
      ctx.fill();
    }

    // X-axis labels drawn on canvas
    var labelEvery = Math.ceil(data.length / 6);
    ctx.font = '10px Inter, sans-serif';
    ctx.fillStyle = '#aaa';
    ctx.textAlign = 'center';
    for (var n = 0; n < data.length; n++) {
      if (n % labelEvery === 0 || n === data.length - 1) {
        var cx = padLeft + n * (barW + barGap) + barW / 2;
        ctx.fillText(data[n].label, cx, H - 6);
      }
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    calcCompound();

    document.getElementById('calcBtn').addEventListener('click', calcCompound);

    document.querySelectorAll('.freq-btn').forEach(function(btn) {
      btn.addEventListener('c