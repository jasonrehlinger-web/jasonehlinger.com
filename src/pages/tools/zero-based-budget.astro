  /* Mini steps */
  .steps-mini { display: flex; flex-direction: column; gap: 0.6rem; }
  .sm-step { display: flex; align-items: flex-start; gap: 0.75rem; font-size: 0.82rem; color: #ccc; line-height: 1.4; }
  .sm-num { background: var(--gold); color: #000; border-radius: 50%; width: 22px; height: 22px; min-width: 22px; display: flex; align-items: center; justify-content: center; font-size: 0.72rem; font-weight: 900; flex-shrink: 0; margin-top: 1px; }

  /* Category list */
  .cat-list { display: flex; flex-direction: column; gap: 0.3rem; }
  .cl-row { display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; padding: 0.25rem 0; border-bottom: 1px solid #f5f5f5; color: #555; }
  .cl-row.gold-row span, .cl-row.gold-row .cl-val { color: var(--gold); font-weight: 700; }
  .cl-val { font-weight: 700; color: var(--black); }

  /* ---- Responsive ---- */
  @media (max-width: 960px) {
    .steps-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 860px) {
    .bud-layout { grid-template-columns: 1fr; }
    .bud-sidebar { position: static; }
    .meta-row { grid-template-columns: 1fr; }
    .steps-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 540px) {
    .steps-grid { grid-template-columns: 1fr; }
  }

  /* ---- Print ---- */
  @media print {
    header, footer, nav, .bsb, .bud-layout, section, .page-hero, style + section { display: none !important; }
    #printView { display: block !important; }
    body { margin: 0; font-family: Arial, sans-serif; color: #000; }
    * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  }
</style>

<script is:inline>
(function() {
  function fmt(n) {
    return '$' + Math.abs(n).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }
  function getVal(el) { return parseFloat(el.value) || 0; }
  function sumInputs(selector) {
    return Array.from(document.querySelectorAll(selector)).reduce(function(s, el) { return s + getVal(el); }, 0);
  }
  function setText(id, val) { var el = document.getElementById(id); if (el) el.textContent = val; }

  function update() {
    var income = sumInputs('.income-input');
    var cats = ['saving','giving','debt','housing','transport','food','util','health','children','personal','entertain','misc'];
    var totalExp = 0;
    cats.forEach(function(cat) {
      var t = sumInputs('.exp-input[data-cat="' + cat + '"]');
      totalExp += t;
      setText('ttl-' + cat, fmt(t));
      setText('cl-' + cat, fmt(t));
    });
    setText('ttl-income', fmt(income));
    setText('cl-income', fmt(income));

    var remaining = income - totalExp;
    var pct = income > 0 ? Math.min((totalExp / income) * 100, 100) : 0;

    setText('bsbIncome', fmt(income));
    setText('bsbBudgeted', fmt(totalExp));

    var remEl = document.getElementById('bsbRemaining');
    if (remEl) {
      if (remaining < 0) { remEl.textContent = '-' + fmt(remaining); remEl.style.color = '#e55'; }
      else { remEl.textContent = fmt(remaining); remEl.style.color = remaining === 0 ? '#4caf50' : 'var(--gold)'; }
    }

    var fill = document.getElementById('bsbFill');
    if (fill) {
      fill.style.width = pct + '%';
      fill.style.background = remaining < 0 ? '#e55' : remaining === 0 ? '#4caf50' : 'var(--gold)';
    }

    var status = document.getElementById('bsbStatus');
    if (status) {
      if (income === 0) { status.textContent = 'Enter your income to get started'; status.style.color = '#888'; }
      else if (remaining === 0) { status.textContent = 'Perfectly zeroed out - every dollar has a job!'; status.style.color = '#4caf50'; }
      else if (remaining < 0) { status.textContent = 'Over budget by ' + fmt(remaining) + ' - find where to cut'; status.style.color = '#e55'; }
      else { status.textContent = fmt(remaining) + ' still needs a job - keep going'; status.style.color = '#888'; }
    }

    var zc = document.getElementById('zeroCard');
    var zi = document.getElementById('zeroIcon');
    var zl = document.getElementById('zeroLabel');
    var zs = document.getElementById('zeroSub');
    if (zc && zi && zl && zs) {
      if (income === 0) { zi.textContent='Target'; zl.textContent='Every Dollar Needs a Job'; zs.textContent='Goal: Income minus Expenses = $0'; zc.style.background=''; zc.style.borderColor='var(--gold)'; }
      else if (remaining === 0) { zi.textContent='Done!'; zl.textContent='Budget Complete!'; zs.textContent='Every dollar is working for you.'; zc.style.background='#f0fff4'; zc.style.borderColor='#4caf50'; }
      else if (remaining < 0) { zi.textContent='!'; zl.textContent='Over Budget'; zs.textContent='Cut ' + fmt(remaining) + ' from expenses.'; zc.style.background='#fff5f5'; zc.style.borderColor='#e55'; }
      else { zi.textContent='$'; zl.textContent=fmt(remaining)+' Left to Assign'; zs.textContent='Keep going until it hits $0.'; zc.style.background=''; zc.style.borderColor='var(--gold)'; }
    }
  }

  function makeRow(labelText, inputClass, dataCat) {
    var row = document.createElement('div');
    row.className = 'li-row';
    var labelInput = document.createElement('input');
    labelInput.type = 'text';
    labelInput.className = 'li-label';
    labelInput.value = labelText;
    var wrap = document.createElement('div');
    wrap.className = 'li-input';
    var sym = document.createElement('span');
    sym.textContent = '$';
    var numInput = document.createElement('input');
    numInput.type = 'number';
    numInput.className = inputClass;
    numInput.min = '0';
    numInput.step = '10';
    numInput.placeholder = '0';
    if (dataCat) numInput.setAttribute('data-cat', dataCat);
    numInput.addEventListener('input', update);
    wrap.appendChild(sym);
    wrap.appendChild(numInput);
    var del = document.createElement('button');
    del.className = 'li-del';
    del.title = 'Remove row';
    del.textContent = 'x';
    del.addEventListener('click', function() { row.remove(); update(); });
    row.appendChild(labelInput);
    row.appendChild(wrap);
    row.appendChild(del);
    return row;
  }

  function getCatRows(catId) {
    var rows = [];
    document.querySelectorAll('#li-' + catId + ' .li-row').forEach(function(row) {
      var labelEl = row.querySelector('.li-label');
      var numEl = row.querySelector('input[type="number"]');
      var val = parseFloat(numEl.value) || 0;
      if (val > 0) rows.push({ label: labelEl.value || 'Item', val: val });
    });
    return rows;
  }

  function downloadPDF() {
    var name = document.getElementById('bName').value || 'My Budget';
    var month = document.getElementById('bMonth').value || new Date().toLocaleDateString('en-US',{month:'long',year:'numeric'});

    var income = sumInputs('.income-input');
    var cats = [
      {id:'saving',label:'Saving and Investing',icon:'Saving'},
      {id:'giving',label:'Giving',icon:'Giving'},
      {id:'debt',label:'Debt Payments',icon:'Debt'},
      {id:'housing',label:'Housing',icon:'Housing'},
      {id:'transport',label:'Transportation',icon:'Transport'},
      {id:'food',label:'Food',icon:'Food'},
      {id:'util',label:'Utilities',icon:'Utilities'},
      {id:'health',label:'Health and Medical',icon:'Health'},
      {id:'children',label:'Children',icon:'Children'},
      {id:'personal',label:'Personal',icon:'Personal'},
      {id:'entertain',label:'Entertainment',icon:'Entertainment'},
      {id:'misc',label:'Miscellaneous',icon:'Misc'}
    ];

    var totalExp = 0;
    var catsHTML = '';
    cats.forEach(function(cat) {
      var rows = getCatRows(cat.id);
      var t = rows.reduce(function(s,r){return s+r.val;},0);
      if (t === 0) return;
      totalExp += t;
      var rowsHTML = rows.map(function(r){return '<tr><td style="padding:2px 8px;font-size:10.5px;color:#444;">'+r.label+'</td><td style="padding:2px 8px;text-align:right;font-size:10.5px;font-weight:600;">'+fmt(r.val)+'</td></tr>';}).join('');
      catsHTML += '<div style="break-inside:avoid;margin-bottom:10px;"><div style="background:#1a1a1a;color:#fff;padding:5px 10px;border-radius:3px 3px 0 0;display:flex;justify-content:space-between;"><span style="font-size:11px;font-weight:700;">'+cat.label+'</span><span style="font-size:11px;font-weight:800;color:#c8982a;">'+fmt(t)+'</span></div><table style="width:100%;border-collapse:collapse;background:#fafafa;">'+rowsHTML+'</table></div>';
    });

    var incomeRows = '';
    document.querySelectorAll('#li-income .li-row').forEach(function(row){
      var labelEl = row.querySelector('.li-label');
      var numEl = row.querySelector('input[type="number"]');
      var val = parseFloat(numEl.value)||0;
      if (val > 0) incomeRows += '<tr><td style="padding:2px 8px;font-size:10.5px;color:#444;">'+(labelEl.value||'Income')+'</td><td style="padding:2px 8px;text-align:right;font-size:10.5px;font-weight:600;">'+fmt(val)+'</td></tr>';
    });

    var remaining = income - totalExp;
    var remColor = remaining < 0 ? '#cc2222' : remaining === 0 ? '#2a8a2a' : '#c8982a';
    var remLabel = remaining < 0 ? 'Over Budget by '+fmt(remaining) : remaining === 0 ? 'Zeroed Out - Every Dollar Has a Job!' : fmt(remaining)+' Left to Assign';

    var stepsHTML = '<div style="margin-top:14px;padding:10px 14px;background:#f9f9f9;border-radius:4px;border-left:3px solid #c8982a;"><div style="font-size:9px;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;color:#c8982a;margin-bottom:6px;">Jason\'s 5-Step Financial Hope Plan</div><div style="display:flex;gap:6px;flex-wrap:wrap;">'
      + ['$1,500 Emergency Fund','Pay Off ALL Debt','3-6 Month Emergency Fund','Pay Off Home + 15% Retirement','Build Legacy Wealth'].map(function(s,i){return '<span style="background:#1a1a1a;color:#fff;padding:3px 8px;border-radius:12px;font-size:9px;font-weight:700;"><span style="color:#c8982a;">'+(i+1)+'.</span> '+s+'</span>';}).join('')
      + '</div></div>';

    var html = '<div style="max-width:780px;margin:0 auto;font-family:Arial,sans-serif;padding:20px;">'
      + '<div style="background:#111;color:#fff;padding:18px 22px;border-radius:6px;margin-bottom:16px;display:flex;justify-content:space-between;align-items:center;">'
      + '<div><div style="color:#c8982a;font-size:9px;font-weight:800;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:3px;">Jason Ehlinger - Personal Finance</div>'
      + '<div style="font-size:20px;font-weight:900;">Monthly Zero-Based Budget</div>'
      + '<div style="color:#aaa;font-size:11px;margin-top:3px;">'+name+' - '+month+'</div></div>'
      + '<div style="text-align:right;"><div style="color:#c8982a;font-size:9px;letter-spacing:0.08em;text-transform:uppercase;font-weight:700;">Every Dollar Has a Job</div>'
      + '<div style="color:#888;font-size:9px;margin-top:3px;">jasonehlinger.com</div></div></div>'
      + '<div style="margin-bottom:14px;"><div style="background:#c8982a;color:#fff;padding:5px 10px;border-radius:3px 3px 0 0;display:flex;justify-content:space-between;">'
      + '<span style="font-size:11px;font-weight:700;">Monthly Income</span><span style="font-size:11px;font-weight:800;">'+fmt(income)+'</span></div>'
      + '<table style="width:100%;border-collapse:collapse;background:#fafafa;">'+incomeRows+'</table></div>'
      + '<div style="columns:2;column-gap:14px;margin-bottom:14px;">'+catsHTML+'</div>'
      + '<div style="background:#f5f5f5;border-radius:4px;padding:12px 14px;display:flex;justify-content:space-between;align-items:center;border:2px solid #ddd;">'
      + '<div style="display:flex;gap:20px;"><div><div style="font-size:9px;color:#888;text-transform:uppercase;letter-spacing:0.06em;">Total Income</div><div style="font-size:15px;font-weight:800;">'+fmt(income)+'</div></div>'
      + '<div><div style="font-size:9px;color:#888;text-transform:uppercase;letter-spacing:0.06em;">Total Budgeted</div><div style="font-size:15px;font-weight:800;">'+fmt(totalExp)+'</div></div></div>'
      + '<div style="text-align:right;"><div style="font-size:9px;color:#888;text-transform:uppercase;letter-spacing:0.06em;">Balance</div>'
      + '<div style="font-size:16px;font-weight:900;color:'+remColor+';">'+remLabel+'</div></div></div>'
      + stepsHTML
      + '<div style="text-align:center;margin-top:14px;color:#aaa;font-size:9px;">jasonehlinger.com - Personal finance coaching and free tools - For planning purposes only.</div>'
      + '</div>';

    var pv = document.getElementById('printView');
    pv.innerHTML = html;
    pv.style.display = 'block';
    window.print();
    setTimeout(function(){ pv.style.display = 'none'; }, 1000);
  }

  function setup() {
    document.querySelectorAll('.income-input, .exp-input').forEach(function(el){
      el.addEventListener('input', update);
    });
    document.querySelectorAll('.li-del').forEach(function(btn){
      btn.addEventListener('click', function(){ btn.closest('.li-row').remove(); update(); });
    });
    document.querySelectorAll('.add-row-btn').forEach(function(btn){
      btn.addEventListener('click', function(){
        var targetId = btn.getAttribute('data-target');
        var type = btn.getAttribute('data-type');
        var cat = btn.getAttribute('data-cat');
        var inputClass = type === 'income' ? 'income-input' : 'exp-input';
        var row = makeRow('New Item', inputClass, cat);
        document.getElementById(targetId).appendChild(row);
        row.querySelector('.li-label').focus();
        row.querySelector('.li-label').select();
        update();
      });
    });
    var dlBtn = document.getElementById('dlBtn');
    if (dlBtn) dlBtn.addEventListener('click', downloadPDF);
    update();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup);
  } else {
    setup();
  }
})();
</script>
