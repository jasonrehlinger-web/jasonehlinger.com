  .zero-card { text-align: center; padding: 1.25rem; border: 2px solid var(--gold); }
  .zero-icon { font-size: 1.8rem; margin-bottom: 0.4rem; }
  .zero-label { font-size: 0.95rem; font-weight: 800; margin-bottom: 0.2rem; }
  .zero-sub { font-size: 0.78rem; color: var(--gray); }

  /* Hope plan sidebar card */
  .hope-plan-card { background: var(--black); color: var(--white); border: none; }
