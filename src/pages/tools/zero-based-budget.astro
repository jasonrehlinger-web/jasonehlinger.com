---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Free Zero-Based Budget Worksheet — Jason Ehlinger"
  description="Build your monthly zero-based budget online for free. Give every dollar a job, track your balance in real time, and download a branded PDF. From Jason Ehlinger."
  keywords="zero based budget template free, monthly budget worksheet, zero based budgeting, budget planner download, Jason Ehlinger budget, personal finance budget template, give every dollar a job"
>

  <section class="page-hero">
    <span class="section-label">Free Tool · Personal Finance</span>
    <h1>Zero-Based Budget Builder</h1>
    <p>Every dollar gets a job before the month starts. Fill in your income and expenses — then download your plan as a PDF.</p>
  </section>

  <!-- 5-STEP FRAMEWORK -->
  <section style="background:var(--black); padding:3rem 1.5rem;">
    <div class="container" style="max-width:1100px;">
      <div style="text-align:center; margin-bottom:2rem;">
        <span class="section-label">The Framework</span>
        <h2 style="font-size:1.8rem; color:var(--white); margin-bottom:0.5rem;">Jason's 5-Step Financial Hope Plan</h2>
        <p style="color:#aaa; font-size:0.95rem;">Work the steps in order. Don't skip ahead. This is how ordinary income becomes extraordinary wealth.</p>
      </div>
      <div class="steps-grid">
        <div class="step-card">
          <div class="step-num">1</div>
          <div class="step-body">
            <h4>$1,500 Starter Emergency Fund</h4>
            <p>Before anything else — a small cash buffer so an unexpected expense doesn't derail you. Fast and focused.</p>
          </div>
        </div>
        <div class="step-card">
          <div class="step-num">2</div>
          <div class="step-body">
            <h4>Pay Off ALL Consumer Debt</h4>
            <p>Credit cards, car payments, student loans — all of it. Debt is a wealth killer. Attack it with intensity until it's gone.</p>
          </div>
        </div>
        <div class="step-card">
          <div class="step-num">3</div>
          <div class="step-body">
            <h4>Fully Funded Emergency Fund</h4>
            <p>3–6 months of living expenses in cash. Now you're protected from life's real surprises — no more going back into debt.</p>
          </div>
        </div>
        <div class="step-card">
          <div class="step-num">4</div>
          <div class="step-body">
            <h4>Pay Off Home Early + 15% to Retirement</h4>
            <p>Invest 15% of household income into retirement and pay extra on your mortgage. Two wealth-building moves working at once.</p>
          </div>
        </div>
        <div class="step-card">
          <div class="step-num">5</div>
          <div class="step-body">
            <h4>Build Legacy Wealth That Lives &amp; Gives</h4>
            <p>Now you build. Invest, give generously, pay off your home if not done, and create wealth that outlasts you.</p>
          </div>
        </div>
      </div>
      <div style="text-align:center; margin-top:2rem;">
        <p style="color:#aaa; font-size:0.9rem; margin-bottom:1rem;">Not sure which step you're on — or how to get to the next one?</p>
        <a href="/contact" class="btn btn-gold">Book a Free Finance Assessment</a>
      </div>
    </div>
  </section>

  <!-- BUDGET TOOL -->
  <section class="section" style="padding-top:0;">
    <div class="container bud-wrap">

      <!-- STICKY SUMMARY BAR -->
      <div class="bsb" id="bsb">
        <div class="bsb-stats">
          <div class="bsb-item">
            <span class="bsb-label">Monthly Income</span>
            <span class="bsb-val" id="bsbIncome">$0</span>
          </div>
          <div class="bsb-div"></div>
          <div class="bsb-item">
            <span class="bsb-label">Total Budgeted</span>
            <span class="bsb-val" id="bsbBudgeted">$0</span>
          </div>
          <div class="bsb-div"></div>
          <div class="bsb-item">
            <span class="bsb-label">Left to Assign</span>
            <span class="bsb-val bsb-remaining" id="bsbRemaining">$0</span>
          </div>
        </div>
        <div class="bsb-progress">
          <div class="bsb-track"><div class="bsb-fill" id="bsbFill" style="width:0%"></div></div>
          <span class="bsb-status" id="bsbStatus">Enter your income to get started</span>
        </div>
        <button class="btn btn-gold bsb-dl" id="dlBtn">⬇ Download PDF</button>
      </div>

      <!-- MAIN LAYOUT -->
      <div class="bud-layout">

        <!-- LEFT FORM -->
        <div class="bud-form">

          <!-- NAME / MONTH -->
          <div class="bud-card meta-card">
            <div class="meta-row">
              <div class="field-group">
                <label for="bName">Your Name</label>
                <input type="text" id="bName" class="bud-text" placeholder="Jason Ehlinger" />
              </div>
              <div class="field-group">
                <label for="bMonth">Budget Month</label>
                <input type="text" id="bMonth" class="bud-text" placeholder="July 2026" />
              </div>
            </div>
          </div>

          <!-- INCOME -->
          <div class="bud-card" id="cat-income">
            <div class="cat-hdr">
              <span class="cat-icon">💵</span>
              <h3>Monthly Income</h3>
              <span class="cat-ttl" id="ttl-income">$0</span>
            </div>
            <div class="line-items" id="li-income">
              <div class="li-row"><input type="text" class="li-label" value="Primary Job / Salary" /><div class="li-input"><span>$</span><input type="number" class="income-input" min="0" step="50" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Spouse / Partner Income" /><div class="li-input"><span>$</span><input type="number" class="income-input" min="0" step="50" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Side Hustle / Freelance" /><div class="li-input"><span>$</span><input type="number" class="income-input" min="0" step="50" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Rental Income" /><div class="li-input"><span>$</span><input type="number" class="income-input" min="0" step="50" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Other Income" /><div class="li-input"><span>$</span><input type="number" class="income-input" min="0" step="50" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
            </div>
            <button class="add-row-btn" data-target="li-income" data-type="income">+ Add Income Source</button>
          </div>

          <!-- SAVING & INVESTING -->
          <div class="bud-card">
            <div class="cat-hdr">
              <span class="cat-icon">📈</span>
              <h3>Saving &amp; Investing</h3>
              <span class="cat-ttl" id="ttl-saving">$0</span>
            </div>
            <p class="cat-tip">Step 1, 3 &amp; 4 — Pay yourself first, before expenses.</p>
            <div class="line-items" id="li-saving">
              <div class="li-row"><input type="text" class="li-label" value="Emergency Fund (Step 1 → $1,500)" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="saving" min="0" step="25" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Retirement — 401k / IRA (Step 4 → 15%)" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="saving" min="0" step="25" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Fully Funded Emergency Fund (Step 3)" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="saving" min="0" step="25" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Other Investments (Step 5)" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="saving" min="0" step="25" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Sinking Funds (car, vacation, repairs…)" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="saving" min="0" step="25" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
            </div>
            <button class="add-row-btn" data-target="li-saving" data-type="exp" data-cat="saving">+ Add Item</button>
          </div>

          <!-- GIVING -->
          <div class="bud-card">
            <div class="cat-hdr">
              <span class="cat-icon">🤝</span>
              <h3>Giving</h3>
              <span class="cat-ttl" id="ttl-giving">$0</span>
            </div>
            <div class="line-items" id="li-giving">
              <div class="li-row"><input type="text" class="li-label" value="Tithes / Offering" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="giving" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Charity / Donations" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="giving" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
            </div>
            <button class="add-row-btn" data-target="li-giving" data-type="exp" data-cat="giving">+ Add Item</button>
          </div>

          <!-- DEBT PAYMENTS -->
          <div class="bud-card">
            <div class="cat-hdr">
              <span class="cat-icon">💳</span>
              <h3>Debt Payments</h3>
              <span class="cat-ttl" id="ttl-debt">$0</span>
            </div>
            <p class="cat-tip">Step 2 — List every debt. Attack the smallest balance first.</p>
            <div class="line-items" id="li-debt">
              <div class="li-row"><input type="text" class="li-label" value="Credit Card 1" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="debt" min="0" step="25" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Credit Card 2" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="debt" min="0" step="25" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Car Payment" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="debt" min="0" step="25" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Student Loans" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="debt" min="0" step="25" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Medical Debt" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="debt" min="0" step="25" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Other Debt" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="debt" min="0" step="25" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
            </div>
            <button class="add-row-btn" data-target="li-debt" data-type="exp" data-cat="debt">+ Add Debt</button>
          </div>

          <!-- HOUSING -->
          <div class="bud-card">
            <div class="cat-hdr">
              <span class="cat-icon">🏠</span>
              <h3>Housing</h3>
              <span class="cat-ttl" id="ttl-housing">$0</span>
            </div>
            <div class="line-items" id="li-housing">
              <div class="li-row"><input type="text" class="li-label" value="Mortgage / Rent" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="housing" min="0" step="50" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Extra Mortgage Payment (Step 4)" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="housing" min="0" step="50" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Property Taxes" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="housing" min="0" step="25" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Homeowner's / Renter's Insurance" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="housing" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="HOA Dues" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="housing" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Home Repairs / Maintenance" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="housing" min="0" step="25" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
            </div>
            <button class="add-row-btn" data-target="li-housing" data-type="exp" data-cat="housing">+ Add Item</button>
          </div>

          <!-- TRANSPORTATION -->
          <div class="bud-card">
            <div class="cat-hdr">
              <span class="cat-icon">🚗</span>
              <h3>Transportation</h3>
              <span class="cat-ttl" id="ttl-transport">$0</span>
            </div>
            <div class="line-items" id="li-transport">
              <div class="li-row"><input type="text" class="li-label" value="Car Insurance" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="transport" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Gas" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="transport" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Car Maintenance / Registration" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="transport" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Parking / Tolls / Rideshare" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="transport" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
            </div>
            <button class="add-row-btn" data-target="li-transport" data-type="exp" data-cat="transport">+ Add Item</button>
          </div>

          <!-- FOOD -->
          <div class="bud-card">
            <div class="cat-hdr">
              <span class="cat-icon">🛒</span>
              <h3>Food</h3>
              <span class="cat-ttl" id="ttl-food">$0</span>
            </div>
            <div class="line-items" id="li-food">
              <div class="li-row"><input type="text" class="li-label" value="Groceries" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="food" min="0" step="25" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Dining Out / Restaurants" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="food" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Coffee / Drinks" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="food" min="0" step="5" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Work Lunches" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="food" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
            </div>
            <button class="add-row-btn" data-target="li-food" data-type="exp" data-cat="food">+ Add Item</button>
          </div>

          <!-- UTILITIES -->
          <div class="bud-card">
            <div class="cat-hdr">
              <span class="cat-icon">💡</span>
              <h3>Utilities</h3>
              <span class="cat-ttl" id="ttl-util">$0</span>
            </div>
            <div class="line-items" id="li-util">
              <div class="li-row"><input type="text" class="li-label" value="Electric" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="util" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Gas / Heat" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="util" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Water / Sewer / Trash" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="util" min="0" step="5" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Internet" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="util" min="0" step="5" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Cell Phone(s)" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="util" min="0" step="5" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Streaming &amp; Subscriptions" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="util" min="0" step="5" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
            </div>
            <button class="add-row-btn" data-target="li-util" data-type="exp" data-cat="util">+ Add Item</button>
          </div>

          <!-- HEALTH & MEDICAL -->
          <div class="bud-card">
            <div class="cat-hdr">
              <span class="cat-icon">🏥</span>
              <h3>Health &amp; Medical</h3>
              <span class="cat-ttl" id="ttl-health">$0</span>
            </div>
            <div class="line-items" id="li-health">
              <div class="li-row"><input type="text" class="li-label" value="Health Insurance" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="health" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Dental / Vision Insurance" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="health" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Prescriptions / Copays" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="health" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Gym / Fitness" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="health" min="0" step="5" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
            </div>
            <button class="add-row-btn" data-target="li-health" data-type="exp" data-cat="health">+ Add Item</button>
          </div>

          <!-- CHILDREN -->
          <div class="bud-card">
            <div class="cat-hdr">
              <span class="cat-icon">👧</span>
              <h3>Children</h3>
              <span class="cat-ttl" id="ttl-children">$0</span>
            </div>
            <div class="line-items" id="li-children">
              <div class="li-row"><input type="text" class="li-label" value="Childcare / Daycare" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="children" min="0" step="25" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="School / Tuition / Supplies" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="children" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Activities / Sports / Clubs" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="children" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Allowance" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="children" min="0" step="5" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
            </div>
            <button class="add-row-btn" data-target="li-children" data-type="exp" data-cat="children">+ Add Item</button>
          </div>

          <!-- PERSONAL -->
          <div class="bud-card">
            <div class="cat-hdr">
              <span class="cat-icon">🧴</span>
              <h3>Personal</h3>
              <span class="cat-ttl" id="ttl-personal">$0</span>
            </div>
            <div class="line-items" id="li-personal">
              <div class="li-row"><input type="text" class="li-label" value="Clothing / Shoes" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="personal" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Personal Care / Haircuts" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="personal" min="0" step="10" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
              <div class="li-row"><input type="text" class="li-label" value="Cosmetics / Toiletries" /><div class="li-input"><span>$</span><input type="number" class="exp-input" data-cat="personal" min="0" step="5" placeholder="0" /></div><button class="li-del" title="Remove row">×</button></div>
            </div>
            <button class="add-row-btn" data-target="li-personal" data-type="exp" data-cat="personal">+ Add Item</button>
          </div>

          <!-- ENTERTAINMENT -->
          <div class="bud-card">
            <div class="cat-hdr">
              <span class="cat-icon">🎉</span>
              <h3>Entertainment &amp; Fun</h3>
              <span class="cat-ttl" id="ttl-entertain">$0</span>
            </div>
            <div class="line-items" id="li-entertain">
