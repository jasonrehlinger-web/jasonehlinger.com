---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

// Build topic list with counts, in a fixed, sensible order.
const order = ['Leadership', 'Finance'];
const categories = order
  .map(name => ({ name, count: posts.filter(p => p.data.category === name).length }))
  .filter(c => c.count > 0);
---

<Layout
  title="Blog — Leadership & Personal Finance Insights"
  description="Articles on leadership development, personal finance, wealth building, team management, and entrepreneurship from Jason Ehlinger — CEO of Taika Translations and U.S. Air Force veteran."
  keywords="leadership articles, personal finance blog, wealth building tips, entrepreneur blog, team building advice, leadership development articles, financial freedom blog, business coaching insights, manager to leader, zero-based budgeting tips"
>

  <section class="page-hero">
    <span class="section-label">Insights</span>
    <h1>Leadership & Finance<br/>From the Trenches</h1>
    <p>No fluff. No filler. Real lessons from building a 7-figure company and a life on purpose.</p>
  </section>

  <section class="section">
    <div class="container blog-wrap">
      <div class="blog-layout">

        <!-- SIDEBAR -->
        <aside class="blog-sidebar">
          <div class="sidebar-card topic-card">
            <h4 class="topic-heading">Topics</h4>
            <nav class="topic-list" id="topicList">
              <button class="topic-item is-active" data-filter="all">
                <span>All Articles</span>
                <span class="topic-count">{posts.length}</span>
              </button>
              {categories.map(cat => (
                <button class="topic-item" data-filter={cat.name}>
                  <span>{cat.name}</span>
                  <span class="topic-count">{cat.count}</span>
                </button>
              ))}
            </nav>
          </div>

          <div class="sidebar-card" style="border:2px solid var(--gold); text-align:center;">
            <h4 style="font-size:0.95rem; font-weight:800; margin-bottom:0.5rem;">Not Sure Where to Start?</h4>
            <p style="font-size:0.85rem; color:var(--gray); margin-bottom:1rem;">Get a free assessment and find the clearest next step for your specific situation.</p>
            <a href="/contact" class="btn btn-gold" style="font-size:0.8rem; padding:0.6rem 1rem; display:block;">Book a Free Call</a>
          </div>
        </aside>

        <!-- POSTS -->
        <div class="blog-main">

          {posts.length === 0 && (
            <p style="color:var(--gray); text-align:center; padding:3rem 0;">
              Posts coming soon. In the meantime, check out the
              <a href="https://www.youtube.com/@Visiontribemoney" target="_blank" style="color:var(--gold);">Vision Tribe Money YouTube channel</a>.
            </p>
          )}

          <p class="topic-empty" id="topicEmpty" style="display:none;">
            No articles in this topic yet — check back soon.
          </p>

          <div id="postList">
            {posts.map(post => (
              <div class="blog-card" data-category={post.data.category}>
                <div class="blog-meta">
                  <span class="post-tag" style="margin-right:0.6rem; vertical-align:middle;">{post.data.category}</span>
                  {formatDate(post.data.date)}
                </div>
                <h3><a href={`/blog/${post.slug}`}>{post.data.title}</a></h3>
                <p>{post.data.description}</p>
                <a href={`/blog/${post.slug}`} style="display:inline-block; margin-top:0.75rem; font-size:0.875rem; font-weight:600; color:var(--gold);">Read more →</a>
              </div>
            ))}
          </div>

        </div>

      </div>
    </div>
  </section>

  <!-- YouTube plug -->
  <section class="section section-gray text-center">
    <div class="container" style="max-width:600px;">
      <span class="section-label">Vision Tribe Money</span>
      <h2 style="font-size:1.8rem; margin-bottom:1rem;">777+ Videos on YouTube</h2>
      <p style="color:var(--gray); margin-bottom:2rem;">From budgeting and wealth building to money in marriage and the mindset shifts that change everything — it's all on the channel.</p>
      <a href="https://www.youtube.com/@Visiontribemoney" target="_blank" rel="noopener" class="btn btn-gold">Watch on YouTube</a>
    </div>
  </section>

</Layout>

<style>
  .blog-wrap { max-width: 1100px; }

  .blog-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .blog-sidebar { position: sticky; top: 90px; }

  .sidebar-card {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 8px;
    padding: 1.25rem;
    margin-bottom: 1.25rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }

  .topic-heading {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray);
    margin-bottom: 0.9rem;
  }

  .topic-list { display: flex; flex-direction: column; gap: 0.3rem; }

  .topic-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.6rem 0.75rem;
    border: none;
    background: transparent;
    border-radius: 6px;
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--gray);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    text-align: left;
  }

  .topic-item:hover { background: var(--light-gray); color: var(--dark); }

  .topic-item.is-active {
    background: var(--black);
    color: var(--white);
  }

  .topic-item.is-active .topic-count {
    background: var(--gold);
    color: var(--black);
  }

  .topic-count {
    font-size: 0.72rem;
    font-weight: 700;
    background: var(--light-gray);
    color: var(--gray);
    padding: 0.1rem 0.5rem;
    border-radius: 100px;
    min-width: 1.6em;
    text-align: center;
  }

  .topic-empty {
    color: var(--gray);
    text-align: center;
    padding: 3rem 0;
  }

  .blog-card.is-hidden { display: none; }

  @media (max-width: 860px) {
    .blog-layout { grid-template-columns: 1fr; }
    .blog-sidebar { position: static; }
    .topic-list { flex-direction: row; flex-wrap: wrap; }
    .topic-item { width: auto; }
  }
</style>

<script is:inline>
  document.querySelectorAll('.topic-item').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var filter = btn.getAttribute('data-filter');

      document.querySelectorAll('.topic-item').forEach(function (b) {
        b.classList.toggle('is-active', b === btn);
      });

      var visibleCount = 0;
      document.querySelectorAll('#postList .blog-card').forEach(function (card) {
        var match = filter === 'all' || card.getAttribute('data-category') === filter;
        card.classList.toggle('is-hidden', !match);
        if (match) visibleCount++;
      });

      var empty = document.getElementById('topicEmpty');
      if (empty) empty.style.display = visibleCount === 0 ? 'block' : 'none';
    });
  });
</script>
