---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found" description="This page could not be found.">
  <section class="section" style="text-align:center; min-height:60vh; display:flex; align-items:center;">
    <div class="container">
      <span class="section-label">404</span>
      <h1 style="font-size:3rem; margin-bottom:1rem;">Page Not Found</h1>
      <p style="color:var(--gray); margin-bottom:2rem;">This page doesn't exist — or it's been moved.</p>
      <a href="/" class="btn btn-gold">Back to Home</a>
    </div>
  </section>
</Layout>
